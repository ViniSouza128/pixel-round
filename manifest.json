{
  "id": "/pixel-round/",
  "name": "Pixel Round",
  "short_name": "Pixel Round",
  "description": "A pixel-perfect generator for circles, ellipses, spheres and ellipsoids. Vanilla JS + Canvas + three.js. Works offline.",
